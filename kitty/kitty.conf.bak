# Шрифты (обязательно Nerd Font для иконок lsd и nvim)
font_family      JetBrainsMono Nerd Font
font_size        11.0

# Прозрачность и размытие (на M1/Asahi выглядит супер)
background_opacity 0.85
# Если хочешь совсем минимализм, убери рамки окна
window_padding_width 10

# Тема (Kanagawa - как в ролике)
foreground #DCD7BA
background #1F1F28
selection_foreground #1F1F28
selection_background #DCD7BA

# Цвет курсора и форма
cursor #C8C093
cursor_shape beam
cursor_blink_interval 0.5

# Отключаем звук ошибки (бесит)
enable_audio_bell no
# Отключить подтверждение при закрытии окна
confirm_os_window_close 0

# Настройка вкладок (если пользуешься)
tab_bar_style powerline
active_tab_foreground   #1F1F28
active_tab_background   #7E9CD8

# Включаем след (тень) от курсора
cursor_trail 3

# Настройка затухания (первое число — начало, второе — конец затухания)
cursor_trail_decay 0.1 0.4

# Минимальный порог движения (в пикселях), чтобы тень появилась
cursor_trail_start_threshold 2